{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path].js"
    }
  ],
  "functions": {
    "api/[...path].js": {
      "includeFiles": [
        "server/**",
        "data/muvi.sqlite",
        "data/collision-overrides.json"
      ]
    }
  }
}
